## Memory Management

### Firestore Conversation Memory

Use a custom `BufferWindowMemory` backed by Firestore so conversation history survives across HTTP requests:

```typescript
// memory/firestoreMemory.ts
import { BufferWindowMemory, ChatMessageHistory } from 'langchain/memory';
import { HumanMessage, AIMessage } from '@langchain/core/messages';
import { conversationRepo } from './conversationRepo';

export async function buildMemory(conversationId: string): Promise<BufferWindowMemory> {
  const turns = await conversationRepo.getHistory(conversationId, { limit: 20 });

  const history = new ChatMessageHistory(
    turns.flatMap(t => [new HumanMessage(t.userMessage), new AIMessage(t.assistantMessage)])
  );

  return new BufferWindowMemory({
    k: 10,
    chatHistory: history,
    returnMessages: true,
    memoryKey: 'chat_history',
  });
}
```

Firestore schema — `conversations` collection:

```
conversations/{conversationId}
  userId: string
  createdAt: Timestamp
  updatedAt: Timestamp
  turns: Array<{
    userMessage: string
    assistantMessage: string
    timestamp: Timestamp
    toolsUsed: string[]
  }>
```

### User Context / Client Profile

Firestore schema — `clients` collection:

```
clients/{userId}
  displayName: string
  email: string
  vehicle: {
    make: string       // e.g., "Toyota"
    model: string      // e.g., "Land Cruiser 200"
    year: number       // e.g., 2021
    trim: string?      // e.g., "GX"
    modifications: string[]  // e.g., ["lift kit", "snorkel", "ARB bumper"]
  }
  preferences: {
    terrainTypes: string[]   // e.g., ["sand", "rock crawling", "mud"]
    experience: "beginner" | "intermediate" | "expert"
  }
  createdAt: Timestamp
  updatedAt: Timestamp
```

