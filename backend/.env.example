# Server
PORT=3001

# Firebase Admin SDK — required
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_ID=your-firestore-database-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Optional: Firestore named database (leave blank to use the default "(default)" database)
FIREBASE_DATABASE_ID=

# JWT — required for token signing
JWT_SECRET=your-random-secret-at-least-32-chars

# Mistral AI — required for agent executor
MISTRAL_API_KEY=your-mistral-api-key

# Tavily Search — required for web search tool
TAVILY_API_KEY=your-tavily-api-key
