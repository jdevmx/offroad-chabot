# Server
# Cloud Run injects PORT automatically at runtime.
PORT=8080

# CORS — set to the Firebase Hosting URL in production
CORS_ORIGIN=http://localhost:3000

# Firebase Admin SDK
# On Cloud Run the attached service account provides Application Default Credentials.
# These variables are only required for local development.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# JWT — required for token signing
JWT_SECRET=your-random-secret-at-least-32-chars

# Mistral AI — stored in Secret Manager in production; injected as env var in Cloud Run
MISTRAL_API_KEY=your-mistral-api-key

# Tavily Search — stored in Secret Manager in production; injected as env var in Cloud Run
TAVILY_API_KEY=your-tavily-api-key
